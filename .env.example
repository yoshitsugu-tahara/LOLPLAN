# ── Neon (Postgres) ──
# Neon のダッシュボードで作成したプロジェクトの接続文字列。
# 例: postgresql://user:pass@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL=

# ── Auth.js ──
# `npx auth secret` か `openssl rand -base64 33` で生成したランダム文字列
AUTH_SECRET=

# Google OAuth クライアント情報（Google Cloud Console > 認証情報 で発行）
# 承認済みリダイレクト URI: http://localhost:3000/api/auth/callback/google
#                          https://<本番ドメイン>/api/auth/callback/google
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# ── 招待制 allowlist ──
# このメールは常にログイン可・オーナー（招待を管理できる）として扱う
OWNER_EMAIL=suiseido.thr@gmail.com
